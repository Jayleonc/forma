# ============================================================================
# Forma 配置文件示例
# ============================================================================
# 复制此文件为 .env 并填入实际值

# ----------------------------------------------------------------------------
# API 密钥配置
# ----------------------------------------------------------------------------
# OpenAI API 密钥（用于 VLM 功能）
FORMA_OPENAI_API_KEY="sk-your-api-key-here"

# 或者使用通用的 VLM_API_KEY
# VLM_API_KEY="sk-your-api-key-here"

# ----------------------------------------------------------------------------
# 服务配置
# ----------------------------------------------------------------------------
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 文档转换超时时间（秒）
FORMA_CONVERSION_TIMEOUT=600

# 知识库生成超时时间（秒）
FORMA_QA_TIMEOUT=600

# 数据保存目录
FORMA_DATA_DIR=./data

# Worker 配置
CONVERSION_WORKERS=4
QA_WORKERS=2

# ----------------------------------------------------------------------------
# VLM 配置（可选）
# ----------------------------------------------------------------------------
# VLM 基础 URL（如使用自定义端点）
# VLM_BASE_URL=https://api.openai.com/v1

# VLM 模型名称
# VLM_MODEL=gpt-4o

# AUTO 策略阈值（字符数）
# VLM_AUTO_THRESHOLD=100

# ----------------------------------------------------------------------------
# OCR 配置（可选）
# ----------------------------------------------------------------------------
# 高级 OCR API 密钥
# OCR_API_KEY=your-ocr-api-key

# OCR 基础 URL
# OCR_BASE_URL=https://your-ocr-service.com

# OCR 模型
# OCR_MODEL=got-ocr2_0

# OCR 最大文件大小（MB）
# OCR_MAX_FILE_SIZE=10
